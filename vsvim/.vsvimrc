"relative numbers + current line number
set number relativenumber
"ignore case in search
set ignorecase
"Do not select eol character
set selection=exclusive
"Offset at scrolling
set scrolloff=0

"centering window at search result
nnoremap n nzz
nnoremap N Nzz

"centering window at undo/redo
nnoremap u uzz
nnoremap <C-r> <C-r>zz

"set user bindings key
nnoremap <Space> <Nop>
map <Space> <Leader>

"Insert mode quck exit
inoremap jk <Esc>

"[C]lipboard: copy unnamed register contents to OS clipboard
nnoremap <Leader>c :let @+=@"<CR>
"[C]lipboard: copy selected to OS clipboard
vnoremap <Leader>c \"+y

"[P]aste: paste last yanked text
noremap <Leader>p "0p
noremap <Leader>P "0P

"[S]earch: yank current selection into search buffer
vnoremap <Leader>s \"/y

"[F]ormat: format selection
nnoremap <Leader>f :vsc Edit.FormatSelection<CR>
vnoremap <Leader>f :vsc Edit.FormatSelection<CR>
"[W]rap: Toggle word wrap
nnoremap <Leader>w :vsc Edit.ToggleWordWrap<CR>
"[E]rror: goto next error
nnoremap <Leader>e :vsc ReSharper.ReSharper_GotoNextErrorInSolution<CR>
"[L]ine: toggle line comment
noremap <Leader>l :vsc Edit.ToggleLineComment<CR>
"[I]nt: static_cast<|>
vnoremap <Leader>i <Esc>`>a)<Esc>`<istatic_cast<>(<Esc>hi

"[T]odo: insert "//TODO BVR "
nnoremap <Leader>t O// TODO BVR
